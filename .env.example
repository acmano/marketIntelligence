# ─────────────────────────────────────────────
# Market Intelligence — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ─────────────────────────────────────────────

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=market_intelligence
DB_USER=
DB_PASSWORD=

# API Anthropic (Claude)
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_SPENDING_LIMIT_USD=250

# API OpenAI (embeddings)
# Obtenha em: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# E-mail (envio do PowerPoint semanal)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ti@lorenzetti.com.br
# Lista de destinatários separados por vírgula
PPTX_RECIPIENTS=

# Airflow
AIRFLOW_HOME=/opt/airflow

# Configurações de coleta
# Score mínimo de relevância para gerar embedding (0-10)
MIN_RELEVANCE_SCORE=4
# Score mínimo para incluir no PowerPoint semanal
MIN_PPTX_SCORE=7
# Máximo de artigos por fonte por execução
MAX_ARTICLES_PER_SOURCE=50
