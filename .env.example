# =============================================================================
# Market Intelligence — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados dedicado: market_intelligence
# Variáveis prefixadas com MI_ para não conflitar com outros projetos
# -----------------------------------------------------------------------------
MI_DB_HOST=localhost
MI_DB_PORT=5432
MI_DB_NAME=market_intelligence
MI_DB_USER=mi_app
MI_DB_PASSWORD=

# -----------------------------------------------------------------------------
# API Anthropic (Claude) — https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# API OpenAI (embeddings) — https://platform.openai.com
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# E-mail (envio do PowerPoint semanal)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ti@lorenzetti.com.br
# Destinatários separados por vírgula
PPTX_RECIPIENTS=

# -----------------------------------------------------------------------------
# Parâmetros de negócio
# -----------------------------------------------------------------------------
# Score mínimo (0-10) para gerar embedding do artigo
MI_SCORE_MIN_EMBEDDING=4
# Score mínimo para incluir no PowerPoint semanal
MI_SCORE_MIN_PPTX=7
# Máximo de artigos buscados por fonte por execução
MI_MAX_ARTIGOS_POR_FONTE=50
# Janela de busca semântica em dias (artigos mais antigos não são retornados)
MI_EMBEDDING_DIAS_MAX=90
